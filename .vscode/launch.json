{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run texor VSCode Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/dist/**/*.js"
      ],
      "preLaunchTask": "Build texor VSCode Extension"
    }
  ]
}
